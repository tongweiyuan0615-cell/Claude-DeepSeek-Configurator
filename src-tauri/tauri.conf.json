{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Claude Code DeepSeek Configurator",
  "version": "0.1.2",
  "identifier": "com.deepseek.claude-configurator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Code + DeepSeek V4 配置器",
        "width": 980,
        "height": 720,
        "minWidth": 720,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "ytw",
    "targets": ["msi"],
    "icon": ["icons/icon.ico"],
    "resources": ["resources/node"]
  }
}
